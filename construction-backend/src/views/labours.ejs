<%- include('partials/header', { title: 'Labours' }) %>

<h2 class="mb-4">Labour List</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Wage</th>
        </tr>
    </thead>
    <tbody>

        <% if (labours.length === 0) { %>
            <tr>
                <td colspan="2" class="text-center">No Labours Found</td>
            </tr>
        <% } %>

        <% labours.forEach(labour => { %>
            <tr>
                <td><%= labour.name %></td>
                <td>₹<%= labour.wage %></td>
            </tr>
        <% }) %>

    </tbody>
</table>

<%- include('partials/footer') %>